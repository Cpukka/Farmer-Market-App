// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  emailVerified DateTime?
  image         String?
  role          Role      @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Application relations
  farmerProfile Farmer?
  cart          Cart?
  orders        Order[]
  reviews       Review[]
  notifications Notification[] // Add this
  statusUpdates OrderStatusUpdate[] @relation("StatusUpdateUser") // Add this

  // Many-to-many for helpful votes
  helpfulReviews Review[] @relation("HelpfulReviews")

  // Favorites
  favoriteProducts Product[] @relation("FavoriteProducts")
  favoriteFarmers  Farmer[]  @relation("FavoriteFarmers")

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Farmer {
  id           String  @id @default(cuid())
  userId       String  @unique
  user         User    @relation(fields: [userId], references: [id])
  farmName     String
  description  String?
  location     String
  latitude     Float?
  longitude    Float?
  rating       Float?  @default(0)
  totalSales   Int     @default(0)
  totalReviews Int     @default(0)
  image        String?
  bannerImage  String?

  // Relations
  products Product[]
  orders   Order[]
  reviews  Review[]

  // Many-to-many for favorites
  favoritedBy User[] @relation("FavoriteFarmers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([rating])
  @@index([location])
}

model Product {
  id           String   @id @default(cuid())
  name         String
  description  String?
  price        Float
  unit         String
  category     String
  stock        Int      @default(0)
  avgRating    Float?   @default(0)
  totalReviews Int      @default(0)
  images       String[]
  farmerId     String
  farmer       Farmer   @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  // Relations
  orders    OrderItem[]
  reviews   Review[]
  cartItems CartItem[]

  // Many-to-many for favorites
  favoritedBy User[] @relation("FavoriteProducts")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([farmerId])
  @@index([category])
  @@index([price])
  @@index([avgRating])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

model Order {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  farmerId     String
  farmer       Farmer      @relation(fields: [farmerId], references: [id])
  items        OrderItem[]
  reviews      Review[]
  statusUpdates OrderStatusUpdate[] // Add this line
  totalAmount  Float
  status       OrderStatus @default(PENDING)
  deliveryDate DateTime?
  address      String
  city         String
  zipCode      String
  phone        String
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId])
  @@index([farmerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  createdAt DateTime @default(now())

  @@unique([orderId, productId])
  @@index([orderId])
  @@index([productId])
}

model Review {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  farmerId     String?
  farmer       Farmer?  @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  orderId      String?
  order        Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rating       Int // 1-5 stars
  title        String?
  comment      String
  images       String[] // Allow multiple review images
  helpful      Int      @default(0)
  helpfulUsers User[]   @relation("HelpfulReviews") // Many-to-many for helpful votes
  verified     Boolean  @default(false) // Verified purchase
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, productId])
  @@unique([userId, farmerId])
  @@index([productId])
  @@index([farmerId])
  @@index([rating])
  @@index([createdAt])
  @@index([userId])
}

model OrderStatusUpdate {
  id        String   @id @default(cuid())
  orderId   String
  status    OrderStatus
  updatedBy String
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [updatedBy], references: [id], name: "StatusUpdateUser")

  @@index([orderId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // ORDER_UPDATE, REVIEW, MESSAGE, etc.
  title     String
  message   String
  data      String?  @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model FarmerApplication {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String   @unique
  phone          String?
  farmName       String
  location       String
  farmSize       String?
  products       String
  experience     String?
  certifications String?
  hearAboutUs    String?
  status         String   @default("PENDING") // PENDING, REVIEWED, APPROVED, REJECTED
  notes          String?
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum Role {
  CUSTOMER
  FARMER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}